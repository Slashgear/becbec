---
import site from '../data/site.yaml';

const banner = (site as any).banner;
if (!banner?.active || !banner?.message) return;

const type = banner.type === 'alert' ? 'alert' : 'info';
const id = `banner-${Buffer.from(banner.message).toString('base64').slice(0, 16)}`;
---

<div
  class={`banner banner--${type}`}
  id={id}
  role="alert"
  aria-live="polite"
>
  <div class="banner-inner">
    {banner.link
      ? <a href={banner.link} class="banner-message banner-link">{banner.message}</a>
      : <p class="banner-message">{banner.message}</p>
    }
    <button
      class="banner-close"
      aria-label="Fermer la bannière"
      data-banner-id={id}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
</div>

<script>
  const btn = document.querySelector('[data-banner-id]') as HTMLButtonElement | null;
  if (btn) {
    const key = `dismissed:${btn.dataset.bannerId}`;
    const banner = document.getElementById(btn.dataset.bannerId!);
    if (localStorage.getItem(key)) {
      banner?.remove();
    }
    btn.addEventListener('click', () => {
      localStorage.setItem(key, '1');
      banner?.remove();
    });
  }
</script>

<style>
  .banner {
    width: 100%;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .banner--info {
    background: var(--red-tint);
    border-bottom: 1px solid var(--red-border);
    color: var(--red-dark);
  }

  .banner--alert {
    background: var(--red);
    color: #fff;
  }

  .banner-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: 0.55rem var(--space-md);
    position: relative;
  }

  .banner-message {
    flex: 1;
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }

  .banner-link {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .banner-link:hover { opacity: 0.8; }

  .banner-close {
    position: absolute;
    right: var(--space-md);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: var(--radius);
    opacity: 0.6;
    transition: opacity 0.15s;
    color: inherit;
    flex-shrink: 0;
  }

  .banner-close:hover { opacity: 1; }
  .banner-close:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
</style>